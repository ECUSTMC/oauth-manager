{% extends 'user.base' %}

{% block title %}{{ trans('OAuthRecord::oauth-record.hall-title') }}{% endblock %}

{% block content %}
<div id="oauth-hall">
  {% if apps is empty %}
    <div class="card">
      <div class="card-body text-center py-5">
        <i class="fas fa-store fa-3x text-muted mb-3"></i>
        <h5>{{ trans('OAuthRecord::oauth-record.hall-empty-title') }}</h5>
        <p class="text-muted">{{ trans('OAuthRecord::oauth-record.hall-empty-desc') }}</p>
      </div>
    </div>
  {% else %}
    <div class="row">
      {% for app in apps %}
      <div class="col-md-4 mb-3">
        <div class="card h-100">
          <div class="card-body">
            <div class="d-flex align-items-center mb-2">
              <div class="mr-3" style="width: 40px; height: 40px; flex-shrink: 0; position: relative;">
                <div class="bg-light rounded-circle d-flex align-items-center justify-content-center fallback-icon"
                     style="width: 40px; height: 40px; position: absolute; top: 0; left: 0;">
                  <i class="fas fa-plug text-secondary"></i>
                </div>
                <img class="app-favicon rounded" alt=""
                     data-url="{{ app.url }}"
                     style="width: 40px; height: 40px; display: none; object-fit: contain; position: absolute; top: 0; left: 0; z-index: 1;">
              </div>
              <div style="min-width: 0; flex: 1;">
                <h6 class="mb-0 text-truncate">{{ app.name }}</h6>
                <div class="text-truncate" style="font-size: 0.8rem;">
                  {% if app.url %}
                  <a href="{{ app.url }}" target="_blank" rel="noopener noreferrer" class="text-muted">
                    {{ app.domain }}
                  </a>
                  {% elseif app.domain %}
                  <span class="text-muted">{{ app.domain }}</span>
                  {% endif %}
                </div>
              </div>
            </div>
            <div class="d-flex justify-content-between align-items-center mt-3">
              <div>
                <small class="text-muted mr-2">
                  <i class="fas fa-users"></i>
                  {{ trans('OAuthRecord::oauth-record.hall-user-count', {count: app.user_count}) }}
                </small>
                {% if app.creator %}
                <small class="text-muted">
                  <i class="fas fa-user"></i>
                  {{ app.creator }}
                </small>
                {% endif %}
              </div>
              {% if app.authorized %}
              <span class="badge badge-success">
                <i class="fas fa-check"></i>
                {{ trans('OAuthRecord::oauth-record.hall-authorized') }}
              </span>
              {% else %}
              <span class="badge badge-secondary">
                {{ trans('OAuthRecord::oauth-record.hall-not-authorized') }}
              </span>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  {% endif %}
</div>

<style>
#oauth-hall .card {
  transition: box-shadow 0.2s ease;
}
#oauth-hall .card:hover {
  box-shadow: 0 2px 8px rgba(0,0,0,.12);
}
#oauth-hall .badge {
  font-size: 0.75rem;
}
#oauth-hall a.text-muted:hover {
  text-decoration: underline;
}
</style>
{% endblock %}

{% block before_foot %}
<script>
(function() {
  var favicons = document.querySelectorAll('.app-favicon');
  var timeout = 5000;

  favicons.forEach(function(img) {
    var url = img.dataset.url;
    var fallback = img.nextElementSibling;

    if (!url) return;

    var faviconUrl = url + '/favicon.ico';
    var timer = setTimeout(function() {
      img.onload = null;
      img.onerror = null;
    }, timeout);

    img.onload = function() {
      clearTimeout(timer);
      img.style.display = 'block';
    };
    img.onerror = function() {
      clearTimeout(timer);
      img.style.display = 'none';
    };

    img.src = faviconUrl;
  });
})();
</script>
{% endblock %}
