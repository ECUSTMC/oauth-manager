{% extends 'user.base' %}

{% block title %}{{ trans('OAuthRecord::oauth-record.hall-title') }}{% endblock %}

{% block content %}
<div id="oauth-hall">
  {% if apps is empty %}
    <div class="card">
      <div class="card-body text-center py-5">
        <i class="fas fa-store fa-3x text-muted mb-3"></i>
        <h5>{{ trans('OAuthRecord::oauth-record.hall-empty-title') }}</h5>
        <p class="text-muted">{{ trans('OAuthRecord::oauth-record.hall-empty-desc') }}</p>
      </div>
    </div>
  {% else %}
    <div class="row">
      {% for app in apps %}
      <div class="col-md-4 mb-3">
        <div class="card h-100">
          <div class="card-body">
            <div class="d-flex align-items-center mb-2">
              <div class="bg-light rounded-circle d-flex align-items-center justify-content-center mr-3"
                   style="width: 40px; height: 40px; flex-shrink: 0;">
                <i class="fas fa-plug text-secondary"></i>
              </div>
              <div style="min-width: 0;">
                <h6 class="mb-0 text-truncate">{{ app.name }}</h6>
                {% if app.domain %}
                <small class="text-muted">{{ app.domain }}</small>
                {% endif %}
              </div>
            </div>
            <div class="d-flex justify-content-between align-items-center mt-3">
              <small class="text-muted">
                <i class="fas fa-users"></i>
                {{ trans('OAuthRecord::oauth-record.hall-user-count', {count: app.user_count}) }}
              </small>
              {% if app.authorized %}
              <span class="badge badge-success">
                <i class="fas fa-check"></i>
                {{ trans('OAuthRecord::oauth-record.hall-authorized') }}
              </span>
              {% else %}
              <span class="badge badge-secondary">
                {{ trans('OAuthRecord::oauth-record.hall-not-authorized') }}
              </span>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  {% endif %}
</div>

<style>
#oauth-hall .card {
  transition: box-shadow 0.2s ease;
}
#oauth-hall .card:hover {
  box-shadow: 0 2px 8px rgba(0,0,0,.12);
}
#oauth-hall .badge {
  font-size: 0.75rem;
}
</style>
{% endblock %}
